# StockMatch Server - Environment Variables
# Copy this file to .env and fill in values if needed
#
# OPTION A: Service account key (if gcloud is not available)
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account-key.json
#
# OPTION B: Custom port (default is 3000)
# PORT=3000
#
# Note: the LMM Mismatch Checker's Anthropic/Gemini API keys are entered directly
# in the app (LMM Check panel) and stored in the browser's localStorage — no
# server-side key needed here.
